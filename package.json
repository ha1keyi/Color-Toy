{
    "name": "color-toy-project",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "test": "vitest",
        "test:run": "vitest run",
        "check": "npm run typecheck && npm run lint && npm run test:run && npm run build"
    },
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "eslint": "^9.22.0",
        "eslint-config-prettier": "^10.1.1",
        "globals": "^16.0.0",
        "prettier": "^3.5.3",
        "typescript": "^5.6.0",
        "typescript-eslint": "^8.26.1",
        "vite": "^5.4.0",
        "vitest": "^3.0.8"
    }
}